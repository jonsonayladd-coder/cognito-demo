  .tilt-card__icon {
    width: 52px;
    height: 52px;
    border-radius: 12px;
    background: rgba(200, 149, 42, 0.12);
    border: 1px solid rgba(200, 149, 42, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    flex-shrink: 0;
  }

  .tilt-card__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--cream);
    margin: 0;
  }

  .tilt-card__subtitle {
    font-size: 0.8rem;
    color: var(--cream-faint);
    margin-top: 0.15rem;
  }

  .tilt-card__features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    position: relative;
    z-index: 1;
  }

  .tilt-card__feature {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .tilt-card__feature-icon {
    font-size: 1.2rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .tilt-card__feature strong {
    display: block;
    font-family: var(--font-display);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--cream);
    margin-bottom: 0.2rem;
  }

  .tilt-card__feature p {
    font-size: 0.78rem;
    color: var(--cream-muted);
    line-height: 1.55;
    margin: 0;
  }

  .tilt-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-card);
    position: relative;
    z-index: 1;
  }

  .btn--sm {
    padding: 0.6rem 1.5rem;
    font-size: 0.78rem;
  }

  .tilt-card__tech {
    font-size: 0.7rem;
    color: var(--cream-faint);
    letter-spacing: 0.05em;
    font-family: var(--font-body);
  }

  @media (max-width: 640px) {
    .tilt-card__inner { padding: 1.5rem; }
    .tilt-card__features { grid-template-columns: 1fr; gap: 1rem; }
    .tilt-card__footer { flex-direction: column; gap: 0.75rem; text-align: center; }
    .tilt-card__header { flex-direction: column; text-align: center; }
  }
</style>

<script>
  // ═══════════════════════════════════════════════
  // DEMO AI RESPONSES (no API needed — all scripted)
  // Replace with real API calls per client
  // ═══════════════════════════════════════════════

  const DEMO_RESPONSES: Record<string, {text: string, action?: {label: string, href: string}}> = {
    // Concierge
    'services': {
      text: "We build custom websites, AI-powered chatbots, and e-commerce stores — all on blazing fast infrastructure. Want me to show you some examples?",
      action: { label: 'View Our Work', href: '/about' }
    },
    'pricing': {
      text: "Projects typically range from $2,000 for a brochure site to $8,000+ for full e-commerce with AI. Every project is custom-scoped. Want to chat about yours?",
      action: { label: 'Get a Quote', href: '/contact' }
    },
    'project': {
      text: "Exciting! I'd love to hear about what you're building. Our contact wizard will help us understand exactly what you need.",
      action: { label: 'Start Your Brief', href: '/contact' }
    },
    'browse': {
      text: "Take your time! Scroll down to see our services, try the AI demo, or check out our work. I'm here if you need anything.",
    },
    // Inline demo
    'What services do you offer?': {
      text: "We specialize in three areas: custom web development with Astro and Cloudflare, AI integration (chatbots, smart forms, recommendation engines), and e-commerce with Stripe. Everything is built from scratch — no templates, no WordPress."
    },
    'How much does a website cost?': {
      text: "It depends on complexity. A modern brochure site starts around $2,000. Add e-commerce and you're looking at $4,000-6,000. AI features like chatbots or smart forms add $1,500-3,000. We'll scope it precisely during the consultation — no surprises."
    },
    'How long does a project take?': {
      text: "A standard site takes 2-4 weeks. E-commerce with AI features is typically 4-6 weeks. We work in stages — design, build, review, launch — so you see progress every step of the way."
    },
    // FAQ
    "What's included in a website project?": {
      text: "Every project includes: custom design, responsive development, SEO optimization, Cloudflare hosting setup, analytics integration, and a 30-day support window after launch. We don't just build and disappear."
    },
    'Do you offer ongoing support after launch?': {
      text: "Yes! We offer monthly maintenance plans starting at $150/month that cover updates, security patches, content changes, and priority support. Most clients stay with us long-term."
    },
    'Can you add AI features to my existing site?': {
      text: "Absolutely. We can integrate AI chatbots, smart contact forms, FAQ assistants, or product recommendation engines into any existing website. The AI runs on Cloudflare Workers, so it's fast and cost-effective."
    }
  };

  function getDemoResponse(question: string): string {
    const match = DEMO_RESPONSES[question];
    if (match) return match.text;
    // Fuzzy match
    const lower = question.toLowerCase();
    if (lower.includes('price') || lower.includes('cost') || lower.includes('much')) return DEMO_RESPONSES['pricing'].text;
    if (lower.includes('service') || lower.includes('offer') || lower.includes('do you')) return DEMO_RESPONSES['services'].text;
    if (lower.includes('time') || lower.includes('long') || lower.includes('fast')) return DEMO_RESPONSES['How long does a project take?'].text;
    if (lower.includes('support') || lower.includes('maintenance')) return DEMO_RESPONSES['Do you offer ongoing support after launch?'].text;
    if (lower.includes('ai') || lower.includes('chatbot') || lower.includes('existing')) return DEMO_RESPONSES['Can you add AI features to my existing site?'].text;
    return "Great question! That's something we'd love to discuss in detail. Our team can give you a personalized answer — want to start a conversation?";
  }

  function typeText(el: HTMLElement, text: string, speed = 18): Promise<void> {
    return new Promise((resolve) => {
      let i = 0;
      const finalSpeed = text.length > 150 ? 12 : speed;
      function type() {
        if (i < text.length) {
          el.textContent = (el.textContent || '') + text[i];
          i++;
          setTimeout(type, finalSpeed);
        } else { resolve(); }
      }
      type();
    });
  }

  function createTypingDots(prefix: string): HTMLElement {
    const typing = document.createElement('div');
    typing.classList.add(`${prefix}__typing`);
    for (let i = 0; i < 3; i++) {
      const dot = document.createElement('div');
      dot.classList.add(`${prefix}__typing-dot`);
      typing.appendChild(dot);
    }
    return typing;
  }

  // ═══════════════════════════════════════════
  // 1. AI CONCIERGE
  // ═══════════════════════════════════════════
  (function initConcierge() {
    const textEl = document.getElementById('concierge-text')!;
    const optionsEl = document.getElementById('concierge-options')!;
    const inputWrap = document.getElementById('concierge-input-wrap')!;
    const inputEl = document.getElementById('concierge-input') as HTMLInputElement;
    const sendBtn = document.getElementById('concierge-send')!;

    // Typewriter greeting
    const greeting = "Hey there! What brings you here today?";
    setTimeout(() => typeText(textEl, greeting, 25), 1800);

    // Show options after greeting types
    const options = [
      { label: 'Explore services', key: 'services' },
      { label: 'Get pricing', key: 'pricing' },
      { label: 'Start a project', key: 'project' },
      { label: 'Just browsing', key: 'browse' },
    ];

    setTimeout(() => {
      options.forEach((opt, i) => {
        const btn = document.createElement('button');
        btn.classList.add('concierge__opt');
        btn.textContent = opt.label;
        btn.style.opacity = '0';
        btn.style.transform = 'translateY(10px)';
        optionsEl.appendChild(btn);

        setTimeout(() => {
          btn.style.transition = 'all 0.4s var(--ease-out-expo)';
          btn.style.opacity = '1';
          btn.style.transform = 'translateY(0)';
        }, i * 100);

        btn.addEventListener('click', () => handleConciergeChoice(opt.key));
      });
    }, 1800 + greeting.length * 25 + 300);

    function handleConciergeChoice(key: string) {
      const data = DEMO_RESPONSES[key];
      if (!data) return;

      // Hide options
      optionsEl.style.transition = 'opacity 0.3s ease';
      optionsEl.style.opacity = '0';
      setTimeout(() => { optionsEl.style.display = 'none'; }, 300);

      // Show response
      const response = document.createElement('div');
      response.classList.add('concierge__response');

      const respText = document.createElement('div');
      respText.classList.add('concierge__response-text');
      response.appendChild(respText);

      if (data.action) {
        const link = document.createElement('a');
        link.classList.add('concierge__response-action');
        link.href = data.action.href;
        link.textContent = data.action.label;
        link.style.opacity = '0';
        response.appendChild(link);
        setTimeout(() => { link.style.transition = 'opacity 0.4s ease'; link.style.opacity = '1'; }, data.text.length * 14 + 200);
      }

      const concierge = document.getElementById('concierge')!;
      concierge.appendChild(response);

      typeText(respText, data.text, 14);

      // Show input for follow-up
      setTimeout(() => {
        inputWrap.style.display = 'flex';
        inputWrap.style.animation = 'concFadeIn 0.4s ease-out';
      }, data.text.length * 14 + 500);
    }

    function handleConciergeInput() {
      const text = inputEl.value.trim();
      if (!text) return;
      inputEl.value = '';
      const reply = getDemoResponse(text);

      // Clear previous response
      const prev = document.querySelector('.concierge__response');
      if (prev) prev.remove();

      handleConciergeChoice(
        text.toLowerCase().includes('price') ? 'pricing' :
        text.toLowerCase().includes('service') ? 'services' :
        text.toLowerCase().includes('project') || text.toLowerCase().includes('start') ? 'project' : 'browse'
      );
    }

    sendBtn.addEventListener('click', handleConciergeInput);
    inputEl.addEventListener('keydown', (e) => { if (e.key === 'Enter') handleConciergeInput(); });
  })();

  // ═══════════════════════════════════════════
  // 5. INLINE AI DEMO
  // ═══════════════════════════════════════════
  (function initInlineDemo() {
    const messagesEl = document.getElementById('demo-messages')!;
    const suggestionsEl = document.getElementById('demo-suggestions')!;
    const inputEl = document.getElementById('demo-input') as HTMLInputElement;
    const sendBtn = document.getElementById('demo-send')!;
    let busy = false;

    function addDemoMsg(text: string, role: 'user' | 'ai', animate = true) {
      const msg = document.createElement('div');
      msg.classList.add('ai-demo__msg', `ai-demo__msg--${role}`);
      const textEl = document.createElement('div');
      textEl.classList.add('ai-demo__msg-text');
      msg.appendChild(textEl);
      messagesEl.appendChild(msg);
      messagesEl.scrollTop = messagesEl.scrollHeight;

      if (role === 'ai' && animate) {
        typeText(textEl, text, 14).then(() => { busy = false; inputEl.disabled = false; });
      } else {
        textEl.textContent = text;
      }
    }

    async function askDemo(question: string) {
      if (busy) return;
      busy = true;
      inputEl.disabled = true;

      // Hide suggestions after first use
      suggestionsEl.style.transition = 'opacity 0.3s ease, height 0.3s ease';
      suggestionsEl.style.opacity = '0';
      setTimeout(() => { suggestionsEl.style.display = 'none'; }, 300);

      addDemoMsg(question, 'user');

      // Typing indicator
      const typing = createTypingDots('ai-demo');
      messagesEl.appendChild(typing);
      messagesEl.scrollTop = messagesEl.scrollHeight;

      await new Promise(r => setTimeout(r, 800 + Math.random() * 600));
      typing.remove();

      const reply = getDemoResponse(question);
      addDemoMsg(reply, 'ai');
    }

    // Chip clicks
    suggestionsEl.querySelectorAll('.ai-demo__chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        const q = (chip as HTMLElement).dataset.question || '';
        askDemo(q);
      });
    });

    // Manual input
    function handleDemoInput() {
      const text = inputEl.value.trim();
      if (!text || busy) return;
      inputEl.value = '';
      askDemo(text);
    }

    sendBtn.addEventListener('click', handleDemoInput);
    inputEl.addEventListener('keydown', (e) => { if (e.key === 'Enter') handleDemoInput(); });
  })();

  // ═══════════════════════════════════════════
  // 3. SMART FAQ
  // ═══════════════════════════════════════════
  (function initSmartFAQ() {
    const answerEl = document.getElementById('faq-answer')!;
    const inputEl = document.getElementById('faq-input') as HTMLInputElement;
    const questions = document.querySelectorAll('.smart-faq__q');

    function showAnswer(question: string, btn?: HTMLElement) {
      // Highlight active button
      questions.forEach(q => q.classList.remove('smart-faq__q--active'));
      if (btn) btn.classList.add('smart-faq__q--active');

      // Clear and show answer
      answerEl.textContent = '';
      const textEl = document.createElement('div');
      textEl.classList.add('smart-faq__answer-text');
      answerEl.appendChild(textEl);

      const reply = getDemoResponse(question);
      typeText(textEl, reply, 14);
    }

    questions.forEach((btn) => {
      btn.addEventListener('click', () => {
        const q = (btn as HTMLElement).dataset.faq || '';
        showAnswer(q, btn as HTMLElement);
      });
    });

    inputEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const text = inputEl.value.trim();
        if (!text) return;
        inputEl.value = '';
        questions.forEach(q => q.classList.remove('smart-faq__q--active'));
        answerEl.textContent = '';
        const textEl = document.createElement('div');
        textEl.classList.add('smart-faq__answer-text');
        answerEl.appendChild(textEl);
        typeText(textEl, getDemoResponse(text), 14);
      }
    });
  })();

  // ═══════════════════════════════════════════
  // TILTING CARD — 3D mouse-follow effect
  // ═══════════════════════════════════════════
  (function initTiltCard() {
    const card = document.getElementById('tilt-card');
    if (!card) return;
    const inner = card.querySelector('.tilt-card__inner') as HTMLElement;
    const glow = card.querySelector('.tilt-card__glow') as HTMLElement;
    const MAX_TILT = 8; // degrees

    card.addEventListener('mousemove', (e: Event) => {
      const me = e as MouseEvent;
      const rect = card.getBoundingClientRect();
      const x = me.clientX - rect.left;
      const y = me.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;

      const rotateY = ((x - centerX) / centerX) * MAX_TILT;
      const rotateX = ((centerY - y) / centerY) * MAX_TILT;

      inner.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;

      // Move glow to cursor position
      glow.style.left = `${x}px`;
      glow.style.top = `${y}px`;
    });

    card.addEventListener('mouseleave', () => {
      inner.style.transform = 'rotateX(0) rotateY(0)';
    });
  })();
</script>
